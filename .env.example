BOT_TOKEN=123456:ABC-DEF...
# Опционально: путь к БД (по умолчанию splitpay.db, для Docker — data/splitpay.db)
# DATABASE_URL=sqlite+aiosqlite:///data/splitpay.db

# Канал для загрузки карточек (рекомендуется для продакшна)
# Без него карточки загружаются в ЛС создателя расхода (работает, но спамит уведомлениями).
# Как получить ID:
#   1. Создайте приватный канал в Telegram
#   2. Добавьте бота как администратора
#   3. Перешлите любое сообщение из канала боту @userinfobot
#   4. Скопируйте ID (начинается с -100)
# UPLOAD_CHAT_ID=-100...
